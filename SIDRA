# Generic SIDRA - System Intrusion Defense & Response Algorithm
# (fully anonymized version - no organization, domain, email, or path markers)

Set-ExecutionPolicy -Scope Process -ExecutionPolicy Bypass -Force

# Prevent multiple instances
$mutexName = "Global\SIDRA_Mutex_{0}" -f ([guid]::NewGuid().ToString("N").Substring(0,8))
$mutex = New-Object System.Threading.Mutex($false, $mutexName)
if (-not $mutex.WaitOne(0)) {
    Write-Host "Another instance is running. Exiting." -ForegroundColor Yellow
    exit 0
}

Register-EngineEvent PowerShell.Exiting -Action {
    if ($mutex) { $mutex.ReleaseMutex(); $mutex.Dispose() }
} | Out-Null

# ────────────────────────────────────────────────
# Configuration - EDIT THESE VALUES AS NEEDED
# ────────────────────────────────────────────────

$defaultConfig = [PSCustomObject]@{
    LogFile              = "$env:ProgramData\SIDRA\logs\ScriptExecution.txt"
    WhitelistFile        = "$env:ProgramData\SIDRA\good.txt"
    BadFile              = "$env:ProgramData\SIDRA\bad.txt"
    SleepIntervalSeconds = 30
    MaxLogSizeBytes      = 100MB
    StopFile             = "$env:ProgramData\SIDRA\stop.txt"
    MaxRetries           = 3
    RetryDelaySeconds    = 5
    LogoffServer         = $null                     # Set if using /SERVER: in logoff command
    AlertEmailFrom       = "alerts@yourdomain.local" # ← CHANGE
    AlertEmailTo         = @("admin1@yourdomain.local", "admin2@yourdomain.local") # ← CHANGE
    SmtpServer           = "smtp.yourdomain.local"   # ← CHANGE (or relay server IP)
    SmtpPort             = 25
    UseSsl               = $false
}

$configFile = if ($env:SIDRA_CONFIG) { $env:SIDRA_CONFIG } else { "$env:ProgramData\SIDRA\config.json" }

$script:config = $defaultConfig

if (Test-Path $configFile) {
    try {
        $loaded = Get-Content $configFile -Raw | ConvertFrom-Json
        foreach ($prop in $defaultConfig.PSObject.Properties.Name) {
            if ($loaded.PSObject.Properties.Name -contains $prop) {
                $script:config.$prop = $loaded.$prop
            }
        }
    } catch {
        Write-Warning "Failed to load config.json - using defaults"
    }
} else {
    # Create default config file
    $dir = Split-Path $configFile -Parent
    if (!(Test-Path $dir)) { New-Item -ItemType Directory -Path $dir -Force | Out-Null }
    $defaultConfig | ConvertTo-Json -Depth 5 | Set-Content $configFile -Force
}

# Ensure log directory exists
$logDir = Split-Path $script:config.LogFile -Parent
if (!(Test-Path $logDir)) { New-Item -ItemType Directory -Path $logDir -Force | Out-Null }

# Event Log source
$eventSource = "SIDRA-Script"
if (-not [System.Diagnostics.EventLog]::SourceExists($eventSource)) {
    try { New-EventLog -LogName "Application" -Source $eventSource -ErrorAction Stop } catch {}
}

$script:eventSource = $eventSource

# ────────────────────────────────────────────────
# Core lists
# ────────────────────────────────────────────────

$systemAccounts = @(
    'system', 'localservice', 'networkservice', 'localsystem',
    'dwm-*', 'umfd-*', 'anonymoulogon', 'administrator', 'krbtgt', 'guest'
)

# Add detected SQL service accounts (if any)
try {
    $sqlAccts = Get-CimInstance Win32_Service |
        Where-Object { $_.StartName -match 'NT SERVICE\\|MSSQL|SQLAgent' } |
        ForEach-Object { ($_.StartName -split '\\')[-1].ToLower() } |
        Where-Object { $_ } | Select-Object -Unique
    $systemAccounts += $sqlAccts
} catch {}

$remotePrograms = @(
    @{ Name = "LogMeIn";     ProcessName = "LogMeIn";      ServiceName = "LogMeIn";      Port = 2002  },
    @{ Name = "TeamViewer";  ProcessName = "TeamViewer";   ServiceName = "TeamViewer*";  Port = 5938  },
    @{ Name = "Splashtop";   ProcessName = "SRService";    ServiceName = "Splashtop*";   Port = $null },
    @{ Name = "AnyDesk";     ProcessName = "AnyDesk";      ServiceName = "AnyDesk";      Port = 7070  },
    @{ Name = "VNC";         ProcessName = "winvnc|uvnc";  ServiceName = "vnc*|uvnc*";   Port = 5900  }
)

# Load whitelist (authorized users - one per line, ignore # comments)
$whitelist = @()
$wlPath = $script:config.WhitelistFile

if (Test-Path $wlPath) {
    $whitelist = Get-Content $wlPath -ErrorAction SilentlyContinue |
                 Where-Object { $_ -match '\S' -and $_ -notmatch '^\s*#' } |
                 ForEach-Object { $_.Trim().ToLower() } |
                 Select-Object -Unique
} else {
    # Create empty template
    $dir = Split-Path $wlPath -Parent
    if (!(Test-Path $dir)) { New-Item -ItemType Directory -Path $dir -Force | Out-Null }
    "# Authorized users (one per line - lowercase)" | Out-File $wlPath -Encoding utf8
    Write-Warning "Whitelist file created empty at $wlPath - ADD USERS!"
}

if ($whitelist.Count -eq 0) {
    Write-Warning "Whitelist is EMPTY → running in maximum security mode (blocks almost everything)"
}

$script:activeUnauthorizedSessions = @{}

$lastUnauthorizedTime = $null

# ────────────────────────────────────────────────
# Helper Functions (mostly unchanged, just path-agnostic)
# ────────────────────────────────────────────────

function LogMessage {
    param([string]$Message, [string]$EventType = "Information", [int]$EventId = 1001)

    $ts = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $entry = "$ts - $Message"

    try {
        $log = $script:config.LogFile
        $dir = Split-Path $log -Parent
        if (!(Test-Path $dir)) { New-Item -ItemType Directory -Path $dir -Force | Out-Null }

        $max = $script:config.MaxLogSizeBytes
        if ((Test-Path $log) -and (Get-Item $log).Length -gt $max) {
            $bak = "$log.$(Get-Date -Format 'yyyyMMdd_HHmmss').bak"
            Move-Item $log $bak -Force
        }

        Add-Content -Path $log -Value $entry -ErrorAction Stop
        Write-Host $entry

        if ($script:eventSource) {
            Write-EventLog -LogName Application -Source $script:eventSource -EventId $EventId -EntryType $EventType -Message $Message -ErrorAction SilentlyContinue
        }
    } catch {
        Write-Host "Log write failed: $_" -ForegroundColor Red
    }
}

function Send-AlertEmail {
    param([string]$Subject, [string]$Body, [string[]]$Attachments = @())

    if (-not $script:config.AlertEmailTo -or -not $script:config.SmtpServer) { return }

    try {
        $params = @{
            From       = $script:config.AlertEmailFrom
            To         = $script:config.AlertEmailTo
            Subject    = $Subject
            Body       = $Body
            SmtpServer = $script:config.SmtpServer
            Port       = $script:config.SmtpPort
            Attachments = $Attachments
        }
        if ($script:config.UseSsl) { $params.UseSsl = $true }

        Send-MailMessage @params -ErrorAction Stop
        LogMessage "Email alert sent: $Subject"
    } catch {
        LogMessage "Email failed: $_" "Error" 1032
    }
}

